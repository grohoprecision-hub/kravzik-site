---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Kravzik | Request Quote for Precision Metal Stamping"
  description="Contact Kravzik for custom metal stamping projects. Submit your drawings for a free feasibility analysis and quotation within 24 hours. IATF 16949 certified manufacturer."
>
  <section class="bg-navy-900 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-accent text-sm font-semibold uppercase tracking-wider mb-3">Contact</p>
      <h1 class="text-white mb-4">Start Your Project</h1>
      <p class="text-steel-300 text-lg max-w-2xl">
        Submit your requirements below. Our engineering team reviews every inquiry and responds with a feasibility analysis within 24 hours.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Contact Info -->
        <div class="lg:col-span-1 space-y-6">
          <div>
            <h3 class="text-sm font-semibold text-navy-900 uppercase tracking-wider mb-2">Email</h3>
            <p class="text-sm text-steel-500">info@kravzik.com</p>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-navy-900 uppercase tracking-wider mb-2">Response Time</h3>
            <p class="text-sm text-steel-500">Within 24 hours</p>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-navy-900 uppercase tracking-wider mb-2">Certifications</h3>
            <div class="flex gap-3 text-xs font-semibold text-steel-500">
              <span class="px-2.5 py-1 bg-steel-100 rounded">IATF 16949</span>
              <span class="px-2.5 py-1 bg-steel-100 rounded">ISO 9001</span>
            </div>
          </div>
        </div>

        <!-- Form -->
        <div class="lg:col-span-2">
          <form class="space-y-5" action="#" method="POST" netlify>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-xs font-semibold text-navy-900 uppercase tracking-wider mb-1.5">Full Name *</label>
                <input type="text" id="name" name="name" required class="w-full px-4 py-2.5 text-sm border border-steel-200 rounded focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors" />
              </div>
              <div>
                <label for="company" class="block text-xs font-semibold text-navy-900 uppercase tracking-wider mb-1.5">Company *</label>
                <input type="text" id="company" name="company" required class="w-full px-4 py-2.5 text-sm border border-steel-200 rounded focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors" />
              </div>
            </div>

            <div>
              <label for="email" class="block text-xs font-semibold text-navy-900 uppercase tracking-wider mb-1.5">Email *</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-2.5 text-sm border border-steel-200 rounded focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors" />
            </div>

            <div>
              <label for="product" class="block text-xs font-semibold text-navy-900 uppercase tracking-wider mb-1.5">Product / Service Interest</label>
              <select id="product" name="product" class="w-full px-4 py-2.5 text-sm border border-steel-200 rounded focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors bg-white">
                <option value="">Please select</option>
                <option value="lead-frames">Lead Frames</option>
                <option value="terminals-contacts">Electrical Terminals &amp; Contacts</option>
                <option value="busbars">Copper Busbars</option>
                <option value="brackets">Automotive Brackets</option>
                <option value="shields">EMI/RFI Shields</option>
                <option value="assemblies">Metal Assemblies</option>
                <option value="progressive-die-stamping">High-Speed Progressive Die Stamping</option>
                <option value="tooling">Progressive Die Tooling</option>
                <option value="prototyping">Rapid Prototyping</option>
                <option value="other">Other / Multiple</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-xs font-semibold text-navy-900 uppercase tracking-wider mb-1.5">
                Project Details *
              </label>
              <textarea id="message" name="message" rows="5" required
                class="w-full px-4 py-2.5 text-sm border border-steel-200 rounded focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors resize-y"
                placeholder="Please include: part description, material requirements, estimated annual volume, target tolerance, and any special requirements."
              ></textarea>
            </div>

            <button type="submit" class="w-full sm:w-auto px-8 py-3.5 text-sm font-semibold text-white bg-accent hover:bg-accent-dark rounded transition-colors">
              Submit Inquiry &rarr;
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
