---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Precision Metal Stamped Parts & Components"
  description="Kravzik manufactures precision metal stamped parts including lead frames, electrical terminals, copper busbars, automotive brackets, EMI/RFI shields, and custom metal assemblies. IATF 16949 certified."
>
  <!-- Page Header -->
  <section class="bg-navy-900 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-accent text-sm font-semibold uppercase tracking-wider mb-3">Products</p>
      <h1 class="text-white mb-4">Precision Metal Stamped Parts</h1>
      <p class="text-steel-300 text-lg max-w-2xl">
        High-volume, tight-tolerance metal stamping for critical applications. Every part manufactured under IATF 16949 quality management with 100% burr-free guarantee.
      </p>
    </div>
  </section>

  <!-- Product Grid -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {[
          {
            title: 'Lead Frames',
            href: '/products/lead-frame/',
            imgPrompt: 'precision metal stamped lead frame component semiconductor IC packaging manufacturing',
            desc: 'Coplanarity-critical stamped leadframes for semiconductor IC packaging. Sub-micron precision with 100% burr-free micro-hole perforation up to 1500 SPM.',
            features: ['Semiconductor IC lead frames', 'Power module leadframes', 'Optocoupler / ASIC lead frames', 'QFN, SOIC, QFP, DIP, BGA packages'],
            materials: 'C19400, C70250, Alloy 42, C18150, C10200',
          },
          {
            title: 'Electrical Terminals & Contacts',
            href: '/products/',
            imgPrompt: 'precision stamped electrical terminals and contacts metal components automotive',
            desc: 'High-conductivity custom terminals and contacts for automotive connectors, relays, and electrical distribution systems.',
            features: ['Automotive connector terminals', 'Relay contacts', 'Battery terminals', 'High-current power contacts'],
            materials: 'C11000, C26000, C51000, Stainless Steel',
          },
          {
            title: 'Copper Busbars',
            href: '/products/',
            imgPrompt: 'stamped copper busbar component electric vehicle power distribution',
            desc: 'High-current stamped and formed copper busbars for EV power modules, inverters, and battery systems.',
            features: ['EV power module busbars', 'Battery interconnect busbars', 'Inverter busbars', 'Laminated busbar assemblies'],
            materials: 'C11000 ETP Copper, C10200 OFHC Copper',
          },
          {
            title: 'Automotive Brackets',
            href: '/products/',
            imgPrompt: 'precision metal stamped automotive bracket structural component',
            desc: 'Structural and mounting brackets manufactured to automotive OEM specifications with tight tolerance control.',
            features: ['Chassis mounting brackets', 'Engine compartment brackets', 'Sensor mounting brackets', 'Structural reinforcement brackets'],
            materials: 'Stainless Steel, HSLA Steel, Aluminum Alloys',
          },
          {
            title: 'EMI/RFI Shields',
            href: '/products/',
            imgPrompt: 'metal EMI RFI shielding enclosure stamped component electronics',
            desc: 'Precision-formed shielding solutions providing reliable electromagnetic and radio frequency interference protection.',
            features: ['Board-level EMI shields', 'RFI shielding enclosures', 'Multi-cavity shield frames', 'Custom shield configurations'],
            materials: 'Nickel Silver, Brass, Copper Alloys, Stainless Steel',
          },
          {
            title: 'Metal Assemblies',
            href: '/products/',
            imgPrompt: 'precision metal stamping assembly multiple components welding manufacturing',
            desc: 'Integrated metal stamping assemblies combining multiple stamped components with precision welding and hardware insertion.',
            features: ['Stamped & welded assemblies', 'Insert-molded assemblies', 'Overmolded stamping assemblies', 'Multi-component riveted assemblies'],
            materials: 'Ferrous & Non-ferrous Alloys, Multiple Material Combos',
          },
        ].map(product => (
          <div class="bg-white rounded-lg border border-steel-200 overflow-hidden hover:border-accent/40 transition-colors">
            <div class="p-6 md:p-8">
              <h2 class="text-xl mb-3">
                <a href={product.href} class="hover:text-accent transition-colors">{product.title}</a>
              </h2>
              <p class="text-steel-400 text-sm leading-relaxed mb-5">{product.desc}</p>

              <div class="grid grid-cols-2 gap-4 mb-5">
                <div>
                  <h4 class="text-xs font-semibold text-navy-900 uppercase tracking-wider mb-2">Key Features</h4>
                  <ul class="space-y-1">
                    {product.features.map(f => (
                      <li class="text-xs text-steel-500 flex items-start gap-1.5">
                        <span class="text-accent mt-0.5 shrink-0">&#10003;</span>
                        {f}
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <h4 class="text-xs font-semibold text-navy-900 uppercase tracking-wider mb-2">Materials</h4>
                  <p class="text-xs text-steel-500">{product.materials}</p>
                </div>
              </div>

              <a href={product.href} class="inline-flex items-center text-sm font-semibold text-accent hover:text-accent-dark transition-colors">
                View details <span class="ml-1">&rarr;</span>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quality CTA -->
  <section class="py-16 bg-steel-100/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="mb-3">Need a Custom Stamped Part?</h2>
      <p class="text-steel-400 mb-6">Send us your technical drawings or specifications. Our engineering team provides a feasibility assessment and quotation within 24 hours.</p>
      <a href="/contact/" class="inline-flex items-center px-8 py-3.5 text-sm font-semibold text-white bg-accent hover:bg-accent-dark rounded transition-colors">
        Request Quote
      </a>
    </div>
  </section>
</BaseLayout>
